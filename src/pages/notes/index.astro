---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const notes = (await getCollection('notes'))
  .filter((n) => {
    const pub = new Date(n.data.published ?? n.data.date);
    return pub.getFullYear() <= now.getFullYear() + 1 && pub <= now;
  })
  .sort(
    (a, b) => new Date(b.data.published ?? b.data.date).valueOf() - new Date(a.data.published ?? a.data.date).valueOf()
  );

// Compute per-year article numbers (earliest = #1)
const byYear: Record<number, typeof notes> = {};
for (const note of notes) {
  const year = new Date(note.data.published ?? note.data.date).getFullYear();
  (byYear[year] ??= []).push(note);
}
const articleNumber = new Map<string, string>();
for (const [year, yearNotes] of Object.entries(byYear)) {
  const sorted = [...yearNotes].sort(
    (a, b) => new Date(a.data.published ?? a.data.date).valueOf() - new Date(b.data.published ?? b.data.date).valueOf()
  );
  sorted.forEach((note, i) => {
    articleNumber.set(note.slug, `#${String(i + 1).padStart(2, '0')}`);
  });
}
---

<BaseLayout
  title="Technical Notes - Jakob Neugebauer"
  description="Architecture decisions, system design patterns, and technical findings."
  activePage="notes"
>
  <h1>Technical Notes</h1>
  <p class="muted" style="margin-bottom: var(--spacing-xl);">
    Experiments, system design explorations, and technical observations
    from building AI systems.
  </p>

  {notes.length === 0 ? (
    <p class="muted">No notes published yet.</p>
  ) : (
    <ul class="notes-list">
      {notes.map((note) => (
        <li class="note-item">
          <h2 class="note-title" style="margin-top: 0;">
            <a href={`/notes/${note.slug}`}>{note.data.title}</a>
          </h2>
          <p class="note-date">{note.data.date} · {articleNumber.get(note.slug)}</p>
          <p class="note-summary" set:html={note.data.summary} />
          <a href={`/notes/${note.slug}`} class="note-read-more">&rarr; Read full note</a>
          {note.data.stack && (
            <div class="note-tags" style="margin-top: var(--spacing-sm);">
              {note.data.stack.map((item: string) => (
                <span class="note-tag">{item}</span>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
