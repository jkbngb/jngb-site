---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---

<BaseLayout
  title={`${note.data.title} - Jakob Neugebauer`}
  description={note.data.summary}
  activePage="notes"
>
  <article>
    <div class="note-back note-back-top">
      <a href="/notes">&larr; All notes</a>
    </div>
    <header>
      <h1>{note.data.title}</h1>
      <p class="note-date">{note.data.date}</p>
      {note.data.stack && (
        <div class="note-tags" style="margin-top: var(--spacing-sm);">
          {note.data.stack.map((item: string) => (
            <span class="note-tag">{item}</span>
          ))}
        </div>
      )}
    </header>

    <div class="note-content">
      <Content />
    </div>

    <p class="note-license">
      Licensed <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="license noopener noreferrer">CC BY 4.0</a>. Quote it, excerpt it, build on it &ndash; credit the author and link back.
    </p>

    <div class="note-back note-back-bottom">
      <a href="/notes">&larr; All notes</a>
    </div>
  </article>

  <script>
    document.querySelectorAll('.gpu-slider').forEach(slider => {
      const overlay = slider.querySelector('.gpu-slider-overlay') as HTMLElement;
      const line = slider.querySelector('.gpu-slider-line') as HTMLElement;
      const range = slider.querySelector('input[type=range]') as HTMLInputElement;
      if (overlay && range) {
        range.addEventListener('input', () => {
          overlay.style.width = range.value + '%';
          if (line) line.style.left = range.value + '%';
        });
      }
    });
  </script>
</BaseLayout>
